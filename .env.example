# Application Port
PORT=8000

# Database Configuration (SQLite by default, swap with PostgreSQL URL in prod)
DATABASE_URL=sqlite:///./resumes.db

# Google Gemini API Configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Folder to store uploaded resume documents
UPLOAD_DIR=uploads

# SMTP Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=True
SMTP_USE_SSL=False

